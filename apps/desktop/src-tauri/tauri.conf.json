{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Finance Manager",
  "version": "0.1.0",
  "identifier": "com.finance-manager.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm --filter server build:sidecar && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Finance Manager",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "externalBin": [
      "binaries/server"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
