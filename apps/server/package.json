{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "build:sidecar": "bun build --compile --target=bun-linux-x64 src/index.bun.ts --outfile=../desktop/src-tauri/binaries/server-x86_64-unknown-linux-gnu && bun build --compile --target=bun-windows-x64 src/index.bun.ts --outfile=../desktop/src-tauri/binaries/server-x86_64-pc-windows-msvc.exe",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@hono/trpc-server": "^0.3.4",
    "@trpc/server": "^11.1.0",
    "better-sqlite3": "^11.10.0",
    "drizzle-orm": "^0.42.0",
    "hono": "^4.7.11",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
